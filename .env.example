# Environment Variables (Example)
# Copy this file to .env.local and fill in your values

# MongoDB Atlas Connection (REQUIRED for data persistence)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# API Keys (Optional - for future integrations)
NEXT_PUBLIC_ANILIST_API_URL=https://graphql.anilist.co

# Analytics (Optional - for Vercel Analytics)
NEXT_PUBLIC_ANALYTICS_ID=UA-XXXXXXXX-X

# Feature Flags
NEXT_PUBLIC_ENABLE_SAMPLE_DATA=true
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=true

# App Config
NEXT_PUBLIC_APP_NAME=Anime Tracker
NEXT_PUBLIC_MAX_ANIME_ENTRIES=1000
NEXT_PUBLIC_AUTO_SAVE_INTERVAL=1000
